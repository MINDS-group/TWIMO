      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="EvaluationService" eSuperTypes="#//AIBasedServices/AIService">
      <eOperations name="assessPerformance" eType="#//PerformanceMetrics"/>
      <eOperations name="validateSafety" eType="#//SafetyReport"/>
      <eOperations name="benchmark" eType="#//BenchmarkResults"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="dataset" eType="#//DataAndEvidence/Dataset"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="validates" eType="#//DataAndEvidence/EvidenceArtifact"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="metric" eType="#//DataAndEvidence/Metric"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="ApplicationContext">
    <eClassifiers xsi:type="ecore:EClass" name="DrivingBehaviour">
      <eOperations name="deploy"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="domain" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
