      <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectives" eType="#//ObjectList"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="deploys" eType="#//DigitalTwin/DigitalTwin"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="applies" eType="#//SimplifiedIntelligentMobility/MobilitySystem"/>
    </eClassifiers>
