  <eSubpackages name="Prediction">
    <eClassifiers xsi:type="ecore:EClass" name="..."/>
    <eClassifiers xsi:type="ecore:EClass" name="Predictor" eSuperTypes="#//Prediction/PredictionService">
      <eOperations name="method" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="run" eType="#//Run/Run"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="PredictionService" eSuperTypes="#//AIBasedServices/AIService">
      <eOperations name="predictTrajectory" eType="#//Trajectory"/>
      <eOperations name="predictBehaviour" eType="#//BehaviourForecast"/>
      <eOperations name="predictRisk" eType="#//RiskAssessment"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="SupervisedLearning" eSuperTypes="http://www.eclipse.org/emf/2002/Ecore#//EObject">
      <eOperations name="train"/>
      <eOperations name="predict"/>
      <eOperations name="evaluate"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="UnsupervisedLearning" eSuperTypes="http://www.eclipse.org/emf/2002/Ecore#//EObject">
      <eOperations name="train"/>
