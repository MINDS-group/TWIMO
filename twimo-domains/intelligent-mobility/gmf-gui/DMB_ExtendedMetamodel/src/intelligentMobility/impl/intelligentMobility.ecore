  <eClassifiers xsi:type="ecore:EEnum" name="DriverType">
    <eLiterals name="Human"/>
    <eLiterals name="Selfdriving" value="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Lanes">
    <eLiterals name="NormalLane"/>
    <eLiterals name="Entry" value="1"/>
    <eLiterals name="Exit" value="2"/>
    <eLiterals name="ExitSection" value="3"/>
    <eLiterals name="EmergencyLane" value="4"/>
    <eLiterals name="RushHourLane" value="5"/>
    <eLiterals name="SecondaryRoad" value="6"/>
    <eLiterals name="ZebraCrossings" value="7"/>
    <eLiterals name="Confluence" value="8"/>
  </eClassifiers>
