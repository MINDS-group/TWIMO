  <eSubpackages name="DataAndEvidence">
    <eClassifiers xsi:type="ecore:EClass" name="Feature">
      <eOperations name="method" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Metric">
      <eOperations name="method" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Dataset">
      <eOperations name="load" eType="#//Data"/>
      <eOperations name="validate" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Boolean"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="category" eType="#//DatasetCategory"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="size" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Int"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="datasource" lowerBound="1"
          upperBound="-1" eType="#//DataAndEvidence/DataSource" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="annotation" lowerBound="1"
          upperBound="-1" eType="#//DataAndEvidence/Annotation" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="DataSource">
      <eOperations name="connect" eType="#//Connection"/>
      <eOperations name="stream" eType="#//DataStream"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="sourceType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="location" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="frequency" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Float"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Annotation">
      <eOperations name="getLabels" eType="#//Label"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="annotationType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="annotator" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="timestamp" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//DateTime"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="confidence" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Float"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="label" lowerBound="1"
          upperBound="-1" eType="#//DataAndEvidence/Label" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="EvidenceArtifact">
      <eOperations name="verify" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Boolean"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="dataset" lowerBound="1"
          upperBound="-1" eType="#//DataAndEvidence/Dataset"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="artifactType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="validationResult" eType="#//ValidationResult"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="provenance" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="timestamp" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//DateTime"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Label">
      <eOperations name="validate" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Boolean"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="labelValue" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="taxonomy" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="Explainability">
    <eClassifiers xsi:type="ecore:EClass" name="NLInterface">
      <eOperations name="generateExplanation" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eOperations name="processQuery" eType="#//Response"/>
      <eOperations name="provideAdvisory" eType="#//Advisory"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="xaiengine" lowerBound="1"
          eType="#//Explainability/XAIEngine"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="explanation" lowerBound="1"
          upperBound="-1" eType="#//Explainability/Explanation"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="advisory" lowerBound="1"
          upperBound="-1" eType="#//Explainability/Advisory"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="queries" eType="#//Evaluation/EvaluationService"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="XAIEngine">
      <eOperations name="explainPrediction" eType="#//Explanation"/>
      <eOperations name="visualizeAttention" eType="#//AttentionMap"/>
      <eOperations name="generateCounterfactual" eType="#//Scenario"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="explains" eType="#//Planning/PlanningService"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="explain" eType="#//Prediction/PredictionService"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Explanation">
      <eOperations name="render" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="explanationType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="content" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="confidence" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Float"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="references" eType="#//List%3CEvidence%3E"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Advisory">
      <eOperations name="deliver"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="advisoryType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="isGoalDriven" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Boolean"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="isStimulusDriven" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//Boolean"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="reccomendation" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="SimplifiedIntelligentMobility">
    <eClassifiers xsi:type="ecore:EClass" name="MobilitySystem" eSuperTypes="#//Model/Model">
