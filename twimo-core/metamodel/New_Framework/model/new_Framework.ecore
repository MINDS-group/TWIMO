    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ReinforcementLearning" eSuperTypes="http://www.eclipse.org/emf/2002/Ecore#//EObject">
      <eOperations name="train"/>
      <eOperations name="reward"/>
      <eOperations name="policyUpdate"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="Perception">
