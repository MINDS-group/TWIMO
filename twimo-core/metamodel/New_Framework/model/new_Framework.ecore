      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Vehicle">
      <eOperations name="method" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Driver">
      <eOperations name="method" eType="#//Type"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="field" eType="#//Type"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="Federation">
    <eClassifiers xsi:type="ecore:EClass" name="FederatedDT">
      <eOperations name="synchronize"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="federationProtocol" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="connectivityLayer" eType="#//NetworkLayer"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="integratedsystem" lowerBound="1"
          upperBound="-1" eType="#//Federation/IntegratedSystem"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="federates" eType="#//DigitalTwin/DigitalTwin"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="IntegratedSystem">
      <eOperations name="integrate"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="systemType" eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="interoperabilityStandard"
          eType="ecore:EDataType http://www.eclipse.org/emf/2003/XMLType#//String"/>
    </eClassifiers>
  </eSubpackages>
</ecore:EPackage>
